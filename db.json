      "correctAnswer": "WHERE",
      "maxScore": 20,
      "order": 1
    },
    {
      "id": "q_sql_002",
      "assessmentId": "assess_sql",
      "type": "MULTIPLE_CHOICE",
      "question": "Which SQL keyword is used to sort data?",
      "options": [
        "WHERE",
        "JOIN",
        "ORDER BY",
        "LIMIT"
      ],
      "correctAnswer": "ORDER BY",
      "maxScore": 20,
      "order": 2
    },
    {
      "id": "q_sql_003",
